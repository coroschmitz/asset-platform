generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── MULTI-TENANCY ───

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  clients   Client[]
  partners  Partner[]
  users     User[]
}

model Client {
  id             String       @id @default(cuid())
  orgId          String
  org            Organization @relation(fields: [orgId], references: [id])
  name           String
  fullName       String
  fmCompany      String?
  fmContactName  String?
  fmContactEmail String?
  fmContactPhone String?
  acctDirector   String?
  customerKey    String       @unique
  logoUrl        String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  locations      Location[]
  assets         Asset[]
  workOrders     WorkOrder[]
  users          ClientUser[]
  config         ClientConfig?
  fmConfigs      FmPlatformConfig[]
  corrigoConfig  CorrigoConfig?
  sustainabilityProjects SustainabilityProject[]
  approvalRules  ApprovalRule[]
  coroTrakImports CoroTrakImport[]
  projects       Project[]
  sustainabilityReports SustainabilityReport[]
}

model ClientConfig {
  id                     String  @id @default(cuid())
  clientId               String  @unique
  client                 Client  @relation(fields: [clientId], references: [id])
  isRequestEnabled       Boolean @default(true)
  isRequestClassEnabled  Boolean @default(true)
  isBillingEnabled       Boolean @default(true)
  isNotificationsEnabled Boolean @default(true)
  isBudgetEnabled        Boolean @default(false)
  isApprovalRequired     Boolean @default(true)
  showPictures           Boolean @default(true)
  showPicturesAsIcons    Boolean @default(false)
  imageSize              Int     @default(35)
  useTagNumber           Boolean @default(true)
  showZeroQuantities     Boolean @default(true)
  rowsPerPage            Int     @default(100)
  allowMultipleRequests  Boolean @default(false)
  labelOverrides         Json?
}

// ─── LOCATIONS ───

model Location {
  id             String       @id @default(cuid())
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id])
  partnerId      String?
  partner        Partner?     @relation(fields: [partnerId], references: [id])
  name           String
  address        String?
  city           String
  state          String
  zip            String?
  lat            Float?
  lng            Float?
  locationType   LocationType @default(PRIMARY)
  code           String
  capacity       Int?
  isActive       Boolean      @default(true)
  buildingCode       String?
  rfidReaderCount    Int?         @default(0)
  hasPortalReader    Boolean      @default(false)
  createdAt      DateTime     @default(now())
  assets         Asset[]
  facilities     Facility[]
  rfidReaders    RfidReader[]
  projects       Project[]
  workOrdersFrom WorkOrder[]  @relation("FromLocation")
  workOrdersTo   WorkOrder[]  @relation("ToLocation")
  sustainabilityProjects SustainabilityProject[]
}

enum LocationType {
  PRIMARY
  BRANCH
  WAREHOUSE
  PARTNER_WH
}

model Facility {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  name       String
  type       String?
  floor      String?
  building   String?
  isActive   Boolean  @default(true)
}

// ─── PARTNER NETWORK ───

model Partner {
  id              String       @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id])
  name            String
  region          String
  states          String[]
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  warehouseSystem String       @default("Windfall/MoveHQ")
  apiEndpoint     String?
  apiKey          String?
  slaTarget       Float        @default(98.0)
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  locations       Location[]
  workOrders      WorkOrder[]
  scorecards      PartnerScorecard[]
}

// ─── ASSET INVENTORY ───

model Asset {
  id                String         @id @default(cuid())
  clientId          String
  client            Client         @relation(fields: [clientId], references: [id])
  locationId        String
  location          Location       @relation(fields: [locationId], references: [id])
  tagNumber         String
  serialNumber      String?
  systemNumber      String?
  description       String
  type              String
  category          String
  manufacturer      String?
  partNumber        String?
  modelNumber       String?
  width             Float?
  height            Float?
  depth             Float?
  primaryMaterial   String?
  primaryColor      String?
  secondaryMaterial String?
  secondaryColor    String?
  attributes        Json?
  originalCost      Float?
  currentValue      Float?
  costCenter        String?
  quantity          Int            @default(1)
  condition         AssetCondition @default(GOOD)
  status            AssetStatus    @default(IN_STORAGE)
  photos            AssetPhoto[]
  dateReceived      DateTime?
  lastAuditDate        DateTime?
  monthlyStorageCost   Float?       @default(25.0)
  lastMovedDate        DateTime?
  dispositionRec       String?
  estimatedResaleValue Float?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  assetClass         AssetClass   @default(OFFICE_FURNITURE)
  rfidTagId          String?      @unique
  rfidEpc            String?      @unique
  lastRfidScanAt     DateTime?
  lastRfidZone       String?
  lastRfidReaderId   String?
  weightLbs          Float?
  hazmatClass        String?
  specialHandling    String?
  warrantyExpiry     DateTime?
  leaseExpiry        DateTime?
  depreciationMethod String?
  usefulLifeMonths   Int?
  carbonFootprintKg  Float?
  circularityScore   Float?
  workOrderItems       WorkOrderItem[]
  dispositions         Disposition[]
  rfidEvents           RfidEvent[]
  rfidAssignments      RfidTagAssignment[]

  @@index([clientId, tagNumber])
  @@index([clientId, status])
  @@index([locationId])
  @@index([type])
  @@index([category])
  @@index([rfidTagId])
  @@index([assetClass])
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum AssetStatus {
  IN_STORAGE
  DEPLOYED
  AVAILABLE
  RESERVED
  IN_TRANSIT
  DECOMMISSIONED
}

enum AssetClass {
  OFFICE_FURNITURE
  LAB_SCIENTIFIC
  TECHNOLOGY_IT
  HEAVY_MACHINERY
  FFE_HOSPITALITY
  FFE_HEALTHCARE
  FFE_EDUCATION
}

enum RfidEventType {
  TAG_READ
  ZONE_ENTER
  ZONE_EXIT
  PORTAL_SCAN
  MANUAL_SCAN
  BULK_SCAN
}

enum ProjectStatus {
  PLANNING
  PROCUREMENT
  RECEIVING
  STAGING
  IN_PROGRESS
  PUNCH_LIST
  COMPLETE
  CLOSED
}

model AssetPhoto {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id])
  url       String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── WORK ORDERS ───

model WorkOrder {
  id               String          @id @default(cuid())
  clientId         String
  client           Client          @relation(fields: [clientId], references: [id])
  partnerId        String?
  partner          Partner?        @relation(fields: [partnerId], references: [id])
  fromLocationId   String?
  fromLocation     Location?       @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocationId     String?
  toLocation       Location?       @relation("ToLocation", fields: [toLocationId], references: [id])
  orderNumber      String          @unique
  sequenceNum      Int
  requestType      String
  requestCategory  String?
  priority         Priority        @default(MEDIUM)
  status           WorkOrderStatus @default(DRAFT)
  requestedBy      String
  requestedByEmail String?
  onsiteContact    String?
  onsitePhone      String?
  createdById      String
  createdBy        User            @relation(fields: [createdById], references: [id])
  jobName          String?
  description      String?
  fromDetail       String?
  toDetail         String?
  poNumber         String?         @db.VarChar(35)
  costCenter       String?         @db.VarChar(35)
  department       String?         @db.VarChar(35)
  glCode           String?         @db.VarChar(35)
  chargeBack       String?         @db.VarChar(35)
  workOrderRef     String?         @db.VarChar(35)
  requestDate      DateTime        @default(now())
  scheduledDate    DateTime?
  completedDate    DateTime?
  respondedAt      DateTime?
  checkedInAt      DateTime?
  checkedInLat     Float?
  checkedInLng     Float?
  checkedOutAt     DateTime?
  completionComments String?
  hoursWorked      Float?
  slaResponseDue   DateTime?
  slaCompletionDue DateTime?
  nteAmount        Float?
  actualHours      Float?
  laborRate        Float?          @default(85.0)
  materialCost     Float?
  totalCost        Float?
  invoiceNumber    String?
  invoicedAt       DateTime?
  externalId       String?
  externalSource   String?
  projectId          String?
  project            Project?     @relation(fields: [projectId], references: [id])
  assetClass         AssetClass?
  moveWeight         Float?
  crewSize           Int?
  truckCount         Int?
  milesDriven        Float?
  carbonEmissionsKg  Float?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  items            WorkOrderItem[]
  logs             ActivityLog[]
  attachments      Attachment[]
  notifications    Notification[]
  approvalSteps    ApprovalStep[]

  @@index([clientId, status])
  @@index([partnerId])
  @@index([orderNumber])
  @@index([externalId, externalSource])
}

enum WorkOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model WorkOrderItem {
  id          String    @id @default(cuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  assetId     String
  asset       Asset     @relation(fields: [assetId], references: [id])
  quantity    Int       @default(1)
  notes       String?
}

// ─── ACTIVITY & AUDIT ───

model ActivityLog {
  id          String     @id @default(cuid())
  workOrderId String?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id])
  userId      String?
  user        User?      @relation(fields: [userId], references: [id])
  type        LogType
  title       String
  text        String?
  isPublic    Boolean    @default(true)
  createdAt   DateTime   @default(now())
}

enum LogType {
  ACTIVITY
  COMMENT
  STATUS_CHANGE
  ASSIGNMENT
  ATTACHMENT
}

model Attachment {
  id           String    @id @default(cuid())
  workOrderId  String
  workOrder    WorkOrder @relation(fields: [workOrderId], references: [id])
  fileName     String
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  uploadedById String
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime  @default(now())
}

model Notification {
  id          String    @id @default(cuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  email       String
  isActive    Boolean   @default(true)
}

// ─── USERS & AUTH ───

model User {
  id          String        @id @default(cuid())
  orgId       String?
  org         Organization? @relation(fields: [orgId], references: [id])
  email       String        @unique
  name        String
  role        UserRole
  avatarUrl   String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  workOrders         WorkOrder[]
  logs               ActivityLog[]
  attachments        Attachment[]
  approvalRules      ApprovalRule[]  @relation("ApprovalRuleApprover")
  approvalSteps      ApprovalStep[]  @relation("ApprovalStepApprover")
}

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  PARTNER_ADMIN
  PARTNER_USER
  CLIENT_ADMIN
  CLIENT_USER
  FM_ADMIN
  FM_USER
  APPROVER
  VIEWER
}

model ClientUser {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id])
  userId   String
  role     String
  class    String?

  @@unique([clientId, userId])
}

// ─── INTEGRATIONS & WEBHOOKS ───

model WebhookLog {
  id          String   @id @default(cuid())
  source      String
  direction   String   @default("inbound")
  event       String?
  payload     Json
  status      String   @default("received")
  errorMsg    String?
  workOrderId String?
  createdAt   DateTime @default(now())
  @@index([source])
  @@index([createdAt])
}

model FmPlatformConfig {
  id             String   @id @default(cuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id])
  platform       String
  tenantId       String?
  apiUrl         String?
  apiKey         String?
  webhookSecret  String?
  fieldMapping   Json?
  settings       Json?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@unique([clientId, platform])
}

// ─── CORRIGO INTEGRATION ───

model CorrigoConfig {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  companyId       String
  apiUrl          String   @default("https://am-apiconnect.corrigo.com/api/v5.4.1")
  clientIdOAuth   String
  clientSecret    String
  accessToken     String?
  tokenExpiresAt  DateTime?
  webhookSecret   String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  fieldMappings   CorrigoFieldMapping[]
  @@unique([clientId])
}

model CorrigoFieldMapping {
  id              String  @id @default(cuid())
  corrigoConfigId String
  corrigoConfig   CorrigoConfig @relation(fields: [corrigoConfigId], references: [id])
  corrigoField    String
  platformField   String
  direction       String  @default("both")
  @@unique([corrigoConfigId, corrigoField])
}

// ─── PARTNER SCORECARDS ───

model PartnerScorecard {
  id                  String   @id @default(cuid())
  partnerId           String
  partner             Partner  @relation(fields: [partnerId], references: [id])
  period              String
  totalOrders         Int      @default(0)
  completedOnTime     Int      @default(0)
  onTimeRate          Float?
  avgResponseHours    Float?
  avgCompletionHours  Float?
  communicationScore  Float?
  qualityScore        Float?
  overallScore        Float?
  cbreStarRating      Float?
  slaComplianceRate   Float?
  calculatedAt        DateTime @default(now())
  @@unique([partnerId, period])
  @@index([partnerId])
}

// ─── DISPOSITIONS ───

model Disposition {
  id               String    @id @default(cuid())
  assetId          String
  asset            Asset     @relation(fields: [assetId], references: [id])
  workOrderId      String?
  projectId        String?
  project          SustainabilityProject? @relation(fields: [projectId], references: [id])
  method           String
  weightLbs        Float?
  materialType     String?
  carbonAvoidedLbs Float?
  recipientOrg     String?
  revenue          Float?
  cost             Float?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  @@index([method])
  @@index([completedAt])
}

// ─── APPROVAL WORKFLOW ───

model ApprovalRule {
  id              String        @id @default(cuid())
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  name            String        @default("")
  triggerField    String
  triggerOperator String
  triggerValue    String
  approverUserId  String
  approverUser    User          @relation("ApprovalRuleApprover", fields: [approverUserId], references: [id])
  approverRole    String?
  sortOrder       Int           @default(0)
  isActive        Boolean       @default(true)
  steps           ApprovalStep[]
}

model ApprovalStep {
  id              String        @id @default(cuid())
  workOrderId     String
  workOrder       WorkOrder     @relation(fields: [workOrderId], references: [id])
  ruleId          String?
  rule            ApprovalRule? @relation(fields: [ruleId], references: [id])
  approverUserId  String
  approver        User          @relation("ApprovalStepApprover", fields: [approverUserId], references: [id])
  status          String        @default("pending")
  notes           String?
  decidedAt       DateTime?
  createdAt       DateTime      @default(now())
}

// ─── SUSTAINABILITY & ESG ───

model SustainabilityProject {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  name            String
  locationId      String?
  location        Location? @relation(fields: [locationId], references: [id])
  startDate       DateTime
  endDate         DateTime?
  status          String   @default("active")
  totalWeightLbs  Float?
  totalDiverted   Float?
  diversionRate   Float?
  co2AvoidedLbs   Float?
  createdAt       DateTime @default(now())
  dispositions    Disposition[]
}

model EmissionFactor {
  id              String  @id @default(cuid())
  materialType    String
  dispositionMethod String
  co2PerTonLbs    Float
  source          String
  year            Int
  @@unique([materialType, dispositionMethod])
}
// ─── COROTRAK INTEGRATION ───

model CoroTrakImport {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  workOrderNumber String
  fileName        String
  totalPersonMoves Int
  totalWorkItems   Int
  originBuildings  String[]
  destBuildings    String[]
  storageCount     Int      @default(0)
  interBuildingCount Int    @default(0)
  intraBuildingCount Int    @default(0)
  status           String   @default("IMPORTED")
  importedAt       DateTime @default(now())
  moves            CoroTrakMove[]
  @@index([clientId])
  @@index([workOrderNumber])
}

model CoroTrakMove {
  id              String   @id @default(cuid())
  importId        String
  import          CoroTrakImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  firstName       String
  lastName        String
  employeeNumber  String
  originLocation  String
  originFloor     String
  originRoom      String
  destLocation    String
  destFloor       String
  destRoom        String
  workItemCount   Int      @default(10)
  isStorage       Boolean  @default(false)
  isInterBuilding Boolean  @default(false)
  status          String   @default("PENDING")
  scannedAt       DateTime?
  completedAt     DateTime?
  rfidVerified    Boolean  @default(false)
  @@index([importId])
  @@index([employeeNumber])
}

// ─── RFID INFRASTRUCTURE ───

model RfidReader {
  id              String   @id @default(cuid())
  locationId      String
  location        Location @relation(fields: [locationId], references: [id])
  name            String
  readerType      String
  zone            String?
  ipAddress       String?
  serialNumber    String?
  antennaCount    Int      @default(1)
  isActive        Boolean  @default(true)
  lastHeartbeat   DateTime?
  createdAt       DateTime @default(now())
  events          RfidEvent[]
  @@index([locationId])
}

model RfidEvent {
  id              String        @id @default(cuid())
  readerId        String?
  reader          RfidReader?   @relation(fields: [readerId], references: [id])
  assetId         String?
  asset           Asset?        @relation(fields: [assetId], references: [id])
  tagId           String
  epc             String?
  eventType       RfidEventType
  zone            String?
  signalStrength  Float?
  latitude        Float?
  longitude       Float?
  scannedBy       String?
  metadata        Json?
  createdAt       DateTime      @default(now())
  @@index([tagId])
  @@index([assetId])
  @@index([createdAt])
  @@index([zone])
}

model RfidTagAssignment {
  id              String   @id @default(cuid())
  assetId         String
  asset           Asset    @relation(fields: [assetId], references: [id])
  tagId           String   @unique
  epc             String   @unique
  tagType         String   @default("UHF_PASSIVE")
  assignedAt      DateTime @default(now())
  assignedBy      String?
  isActive        Boolean  @default(true)
  @@index([assetId])
}

// ─── PROJECT / FF&E ───

model Project {
  id              String        @id @default(cuid())
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  name            String
  projectNumber   String        @unique
  description     String?
  projectType     String
  status          ProjectStatus @default(PLANNING)
  startDate       DateTime?
  targetDate      DateTime?
  completedDate   DateTime?
  budget          Float?
  actualCost      Float?
  locationId      String?
  location        Location?     @relation(fields: [locationId], references: [id])
  generalContractor String?
  projectManager  String?
  totalItems      Int           @default(0)
  receivedItems   Int           @default(0)
  installedItems  Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  milestones      ProjectMilestone[]
  workOrders      WorkOrder[]
  deliveries      ProjectDelivery[]
  @@index([clientId])
  @@index([status])
}

model ProjectMilestone {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  targetDate      DateTime
  completedDate   DateTime?
  dependsOn       String?
  sortOrder       Int      @default(0)
  status          String   @default("PENDING")
  @@index([projectId])
}

model ProjectDelivery {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendorName      String
  poNumber        String?
  expectedDate    DateTime
  receivedDate    DateTime?
  itemCount       Int
  receivedCount   Int      @default(0)
  damagedCount    Int      @default(0)
  stagingZone     String?
  inspectedBy     String?
  notes           String?
  @@index([projectId])
}

// ─── SUSTAINABILITY METRICS ───

model SustainabilityReport {
  id                  String   @id @default(cuid())
  clientId            String
  client              Client   @relation(fields: [clientId], references: [id])
  period              String
  scope3TransportKg   Float    @default(0)
  embodiedCarbonKg    Float    @default(0)
  carbonAvoidedKg     Float    @default(0)
  wasteToLandfillLbs  Float    @default(0)
  wasteDivertedLbs    Float    @default(0)
  diversionRate       Float    @default(0)
  cmur                Float    @default(0)
  itemsReused         Int      @default(0)
  itemsRecycled       Int      @default(0)
  itemsDonated        Int      @default(0)
  itemsDisposed       Int      @default(0)
  totalMovesMiles     Float    @default(0)
  generatedAt         DateTime @default(now())
  @@unique([clientId, period])
  @@index([clientId])
}
